# 核心配置文件 - 项目不可变的配置
# 可变配置请在后台"系统设置"中管理
# 
# 使用说明：
# 1. 复制此文件为 config.yaml
# 2. 修改相关配置项
# 3. 确保 config.yaml 不会被提交到 Git 仓库

# 应用配置
app:
  name: "Go Gin API Admin"
  version: "1.0.0"
  mode: "debug" # debug, release, test
  port: 8099

# 数据库配置
database:
  host: "127.0.0.1"
  port: 3306
  user: "your-db-user"           # 修改为你的数据库用户名
  password: "your-db-password"    # 修改为你的数据库密码
  name: "api_admin"               # 修改为你的数据库名称
  charset: "utf8mb4"
  max_idle_conns: 10
  max_open_conns: 100
  log_mode: false

# JWT 配置
jwt:
  secret: "your-secret-key-change-in-production"  # 生产环境务必修改为随机字符串！
  expires: 86400           # 24小时（秒）
  refresh_expires: 604800  # 7天（秒）

# 管理员配置（仅首次启动时使用，之后由后台管理）
admin:
  email: "admin@example.com"      # 首次启动的管理员邮箱
  password: "admin123"            # 首次启动的管理员密码（登录后请立即修改）

# 静态文件嵌入配置
embed:
  enabled: true # 是否使用嵌入的静态文件（生产环境建议 true）
